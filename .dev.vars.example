# Copy this file to .dev.vars and fill in real values.
# .dev.vars is gitignored — never commit real secrets.
#
# Generate HMAC_SECRET and ADMIN_SECRET with:
#   openssl rand -hex 32
#
# Get RESEND_API_KEY from https://resend.com/api-keys

HMAC_SECRET=replace-with-openssl-rand-hex-32
RESEND_API_KEY=re_replace_with_real_key
ADMIN_SECRET=replace-with-openssl-rand-hex-32
ADMIN_ORIGIN=http://localhost:8787
